# ── LLM ─────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
CEREBRAS_API_KEY=csk_xxxxxxxxxxxxxxxxxxxx

# ── Research ─────────────────────────────────────────
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx

# ── Assets (Optional - fallback SVG used if missing) ─
RAPIDAPI_KEY=your_rapidapi_key_here

# ── YouTube OAuth2 ───────────────────────────────────
# Get these from Google Cloud Console > OAuth 2.0 Client IDs
YOUTUBE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
YOUTUBE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxx

# ── Google Sheets ────────────────────────────────────
# Paste the full JSON content of your service account key file
GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"..."}
SPREADSHEET_ID=your_google_sheet_id_here

# Your YouTube Channel ID (from youtube.com/channel/UC...)
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxx
